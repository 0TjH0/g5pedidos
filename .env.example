# ==============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO (PLANTILLA) — GRUPO 5: PEDIDOS
# ==============================================================================
# Instrucciones:
# 1. Copia este archivo y renómbralo exactamente a `.env` en este mismo directorio.
# 2. Llena las variables con tus credenciales reales locales o de producción.
# 3. ¡ADVERTENCIA! Jamás subas el archivo `.env` final a GitHub (está en .gitignore).
# ==============================================================================

# 🚀 1. Configuración General de la Aplicación
APP_ENV=development
PORT=8050
DEBUG=true

# 🗄️ 2. Persistencia (Base de Datos Relacional PostgreSQL)
# Utilizado por SQLAlchemy en la E3 para garantizar transacciones ACID.
# Formato estándar: postgresql://<usuario>:<password>@<host>:<puerto>/<nombre_db>
DATABASE_URL=postgresql://db_user_grupo5:password_seguro_aqui@supabase_o_render_host:5432/pedidos_db

# 🛡️ 3. Seguridad y Tokens (Integración con Grupo 2)
# URL base del microservicio de Identidad para llamadas síncronas de validación.
G2_AUTH_SERVICE_URL=https://api-grupo2-identidad.onrender.com

# 📦 4. Integraciones Síncronas (Malla de Proveedores Cloud)
# Endpoints reales a los que el Grupo 5 les inyectará cabeceras y payloads.

# Grupo 3 (Catálogo): Requerido para mitigar la brecha volumétrica y consultar pesos/dimensiones.
G3_CATALOGO_SERVICE_URL=https://api-grupo3-catalogo.onrender.com/v1

# Grupo 6 (Despacho): Requerido para el POST de envíos y el worker de Polling con X-Headers.
G6_DESPACHO_SERVICE_URL=https://api-grupo6-despacho.onrender.com/api/v1

# Grupo 8 (Pagos): Requerido para la invocación síncrona del flujo de cobro inicial.
G8_PAGOS_SERVICE_URL=https://api-grupo8-pagos.onrender.com/v1

# 📨 5. Arquitectura Asíncrona (Event Bus / Broker centralizado)
# Servidores de mensajería para publicar ORDER_CREATED y consumir PAYMENT_APPROVED.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT